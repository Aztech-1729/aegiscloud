# Aegis Cloud Environment Configuration
# Copy this to .env and fill in your values

# ============================================
# APPLICATION
# ============================================
APP_NAME=Aegis Cloud
VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# ============================================
# DATABASE (PostgreSQL)
# ============================================
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://aegis:your_strong_password@localhost:5432/aegis_cloud

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# SECURITY
# ============================================
# Generate with: openssl rand -hex 32
SECRET_KEY=change_this_to_a_random_64_character_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# CORS
# ============================================
# Comma-separated list of allowed origins
CORS_ORIGINS=https://aegiscloud.in,https://www.aegiscloud.in

# ============================================
# LEMON SQUEEZY (Payment Processing)
# ============================================
# Get these from: https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=your_lemon_squeezy_api_key
LEMONSQUEEZY_STORE_ID=your_store_id
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret

# Product IDs (create these in Lemon Squeezy dashboard)
LEMONSQUEEZY_PRO_MONTHLY_ID=your_pro_monthly_variant_id
LEMONSQUEEZY_PRO_YEARLY_ID=your_pro_yearly_variant_id
LEMONSQUEEZY_BUSINESS_MONTHLY_ID=your_business_monthly_variant_id
LEMONSQUEEZY_BUSINESS_YEARLY_ID=your_business_yearly_variant_id

# ============================================
# EMAIL (Resend)
# ============================================
# Get from: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=noreply@aegiscloud.in
EMAIL_FROM_NAME=Aegis Cloud

# ============================================
# OAUTH (Optional - for social login)
# ============================================
# Google OAuth: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================
# FRONTEND
# ============================================
FRONTEND_URL=https://aegiscloud.in

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_PER_MINUTE=60

# ============================================
# FILE STORAGE
# ============================================
MAX_UPLOAD_SIZE_MB=100
